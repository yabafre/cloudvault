# ===========================================
# CloudVault Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# App
NODE_ENV=development
API_PORT=4000

# Logging
# trace | debug | info | warn | error | fatal — defaults to "info"
LOG_LEVEL=info

# Database (Neon PostgreSQL)
# DATABASE_URL — pooled endpoint used by PrismaPg at runtime.
#   Append &uselibpqcompat=true to silence the pg sslmode=require deprecation
#   warning until pg v9 ships (sslmode=require becomes verify-full by default).
# DIRECT_URL — unpooled endpoint required for `prisma migrate`, `db push`,
#   and `prisma studio` (Neon's PgBouncer pooler rejects the DDL statements
#   and advisory locks Prisma Migrate needs). Architecture §2.2.
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/cloudvault?sslmode=require&uselibpqcompat=true"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/cloudvault?sslmode=require"

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-me-in-production
JWT_EXPIRES_IN=15m

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# AWS S3
AWS_REGION=eu-west-3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=cloudvault-files

# Cloudflare (optional)
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=

# AWS CDK (story 1-7)
# WEB_ORIGIN — CORS-allowed origin for the S3 bucket (passed as -c webOrigin=… or via env)
WEB_ORIGIN=http://localhost:3000
# ACM_CERT_ARN_PROD — pre-created ACM certificate ARN in eu-west-3 (required for prod synth HTTPS)
#   Leave empty in dev: the ALB falls back to HTTP-only on port 80.
ACM_CERT_ARN_PROD=

# Frontend
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Note: Make sure to add FRONTEND_URL to your .env file

